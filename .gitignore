# Dockerized Codex & Claude Code wrapper repo
# Keep only shared config in version control.
# Ignore local auth, local state, and writable workspace contents.

coder/.codex/*
!coder/.codex/config.toml

coder/.composer/*

coder/.claude/*
!coder/.claude/settings.json

project_workspace/

.DS_Store
.vscode/
.idea/

.env
.env.*
!.env.example

temp_codex_prompts/*